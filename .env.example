# Gather Environment Configuration
# Copy this file to .env and update with your values

# Docker Image Configuration
# GitHub username/organization for pulling pre-built images
# Example: ghcr.io/grantstephens/gather:latest
GITHUB_REPO_OWNER=grantstephens

# PocketBase Admin Credentials
# IMPORTANT: Change these before deploying to production!
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme

# Base URL for your instance (used for ActivityPub federation)
# In production, use your actual domain: https://yourdomain.com
BASE_URL=http://localhost:8090

# Optional: Encryption key for sensitive data
# Generate a random key: openssl rand -hex 32
# PB_ENCRYPTION_KEY=
